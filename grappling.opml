			<outline text="Grounded 50/50">
				<outline text="Initiative">
					<outline text="Setups / Entries">
						<outline text="Example: Sweep single defence leading into Wrestling 50/50" />
					</outline>
					<outline text="Control">
						<outline text="Example: Full control (definition)">
							<outline text="Control opponent&apos;s ankle OR tight waist on their far hip" />
							<outline text="Nearside arm controls far ankle OR tight waist toward their far hip" />
							<outline text="Mirrored turtle positions" />
							<outline text="Facing opposite directions" />
							<outline text="Similar control configuration" />
						</outline>
					</outline>
					<outline text="Offence">
						<outline text="Example: Knock to side" />
					</outline>
					<outline text="Defence / Escapes">
						<outline text="Example: If opponent defends by stepping their leg under their body (blocks knock-to-side):">
							<outline text="Example: Underhook their leg" />
							<outline text="Example: Go over-back with the other arm" />
							<outline text="Example: Drive them sideways" />
							<outline text="Side Control" />
						</outline>
					</outline>
					<outline text="Submissions">
						<outline text="Example: Consolidate dominant position" />
					</outline>
					<outline text="Offensive transitions">
						<outline text="Exit grounded 50/50 to side control â Side Control" />
					</outline>
				</outline>
				<outline text="Defensive">
					<outline text="Setups / Entries">
						<outline text="Example: Opponent initiates Grounded 50/50 from Sweep single" />
					</outline>
					<outline text="Control">
						<outline text="Example: Keep tight control of opponent&apos;s leg and build toward initiative" />
					</outline>
					<outline text="Offence" />
					<outline text="Defence / Escapes">
						<outline text="Example: Maintain tight control so opponent can&apos;t free their leg immediately">
							<outline text="Example: Transition to your own control (ankle grip OR hip/tight-waist grip)" />
						</outline>
					</outline>
					<outline text="Submissions" />
					<outline text="Offensive transitions" />
				</outline>
			</outline>
